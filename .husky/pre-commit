#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only)

echo "Verifying gh safeguard..."
npm run safeguards:verify
if [ $? -ne 0 ]; then
	echo "Safeguard check failed. Run: npm run setup"
	exit 1
fi

echo "Running formatting, linting, and type checking..."
npm run check
if [ $? -ne 0 ]; then
	echo "Checks failed. Please fix the errors before committing."
	exit 1
fi

for file in $STAGED_FILES; do
	if [ -f "$file" ]; then
		git add "$file"
	fi
done

echo "All pre-commit checks passed!"
