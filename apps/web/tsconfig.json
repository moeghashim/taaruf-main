{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"allowJs": false,
		"incremental": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ES2022"
		],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx"
	],
	"exclude": [
		"node_modules"
	]
}
